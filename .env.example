# Agnes AI via OpenClaw (set when you receive hackathon credentials)
OPENCLAW_API_KEY=your_key_here
OPENCLAW_BASE_URL=http://localhost:18789/v1
OPENCLAW_MODEL=agnes-1.5-pro

# Telegram Bot (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# WhatsApp via Twilio (get from twilio.com/console)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
